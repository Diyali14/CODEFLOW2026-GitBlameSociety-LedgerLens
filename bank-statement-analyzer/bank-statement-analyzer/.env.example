# ============================================================
# LedgerLens Backend — Environment Variables (EXAMPLE)
# ============================================================
# Copy this file, rename it to .env (or set these as system /
# container / CI environment variables), and fill in the values.
# NEVER commit the real .env to version control.
# ============================================================

# --- PostgreSQL Database ---
POSTGRES_DATASOURCE_URL=jdbc:postgresql://localhost:5432/bank_ai
POSTGRES_DATASOURCE_USERNAME=bank_ai_user
POSTGRES_DATASOURCE_PASSWORD=your_db_password_here

# --- External AI / Anomaly Detection Service ---
# Leave blank to use the default Render-hosted model
ANOMALY_API_URL=https://anomaly-detection-model-4sk4.onrender.com/detect-anomaly

# --- CORS ---
# The origin of your frontend app that is allowed to call this backend.
# Local development: http://localhost:5173  (Vite default)
# Production:        https://your-app.vercel.app  (no trailing slash)
CORS_ALLOWED_ORIGIN=http://localhost:5173

# --- Server Port ---
# Defaults to 8080 if not set
SERVER_PORT=8080
